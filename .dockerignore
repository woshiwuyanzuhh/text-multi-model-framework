# ── Python 字节码 ──
__pycache__/
*.py[cod]
*.pyo

# ── 虚拟环境 ──
.venv/
venv/
env/

# ── 日志文件 ──
logs/
*.log

# ── 数据库文件 ──
*.db
*.sqlite3

# ── IDE / 编辑器 ──
.idea/
.vscode/
*.swp

# ── macOS ──
.DS_Store

# ── 训练中间产物（推理镜像不需要） ──
models_pruned/

# ── 环境变量文件（不要把密钥构建进镜像！） ──
.env
.env.*

# ── 训练数据（推理镜像只需要 data/stopwords.txt 和 data/tmf_class.txt） ──
data/raw/
data/pre/

# ── 测试文件（生产镜像不需要） ──
tests/

# ── 训练流水线文件（推理镜像不需要） ──
run_pipeline.py
Dockerfile.pipeline

# ── Git / CI / 文档（生产镜像不需要） ──
.git/
.gitignore
docker-compose.yml
Dockerfile
.dockerignore
README.md
CHANGELOG.md
