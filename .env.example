# ============================================================
# TMF 项目环境变量配置模板
#
# 使用方法:
#   1. 复制此文件为 .env:
#      Linux/macOS:  cp .env.example .env
#      Windows:      copy .env.example .env
#   2. 填入真实值后启动:   docker compose up -d
#
# ⚠️ 安全提示: .env 文件包含敏感信息，切勿提交到版本控制
# ============================================================

# ---- Flask 应用配置 ----
# 运行环境: development / production / testing
FLASK_ENV=production

# Flask SECRET_KEY（生产环境必须设置，否则拒绝启动）
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-this-to-a-random-secret-key

# ---- API 认证 ----
# 接口认证密钥（必须设置，客户端通过 Authorization: Bearer <API_KEY> 认证）
API_KEY=please-change-this-to-your-api-key

# ---- 数据库（当前 SQLAlchemy 未启用，预留配置）----
# DATABASE_URL=postgresql://user:pass@localhost:5432/tmf

# ---- CORS 白名单 ----
# 允许的前端来源（逗号分隔），生产环境应设置为实际域名
ALLOWED_ORIGINS=http://localhost:8080

# ---- V4 大模型配置 ----
# OpenAI 兼容 API Key（不设置则 V4 接口不可用）
OPENAI_API_KEY=

# LLM 模型名称
LLM_MODEL_NAME=gpt-3.5-turbo

# LLM API 基础 URL（中国大陆需设置为代理/中转地址，留空则直连 api.openai.com）
LLM_BASE_URL=

# LLM 请求超时时间（秒）
LLM_TIMEOUT=30

# ---- API 限流配置 ----
# v1/v2/v3 本地模型接口限流（按客户端 IP）
RATE_LIMIT_LOCAL=60 per minute

# v4 大模型接口限流（LLM 成本高，限流更严格）
RATE_LIMIT_LLM=10 per minute

# ---- 输入限制 ----
# API 输入文本最大长度（字符数）
MAX_TEXT_LENGTH=5000

# ---- 训练参数（仅训练流水线使用，推理服务不需要）----
# 训练批大小
TRAIN_BATCH_SIZE=32
# 学习率
TRAIN_LEARNING_RATE=2e-5
# 训练轮数
TRAIN_EPOCHS=16
# 最大序列长度
TRAIN_MAX_LEN=32
# DataLoader 工作进程数（Windows 上如遇多进程报错可设为 0）
TRAIN_NUM_WORKERS=4
# 训练采样数量（-1 表示全量）
TRAIN_SAMPLE_SIZE=-1
